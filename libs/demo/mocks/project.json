{
  "name": "demo-mocks",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/demo/mocks/src",
  "projectType": "library",
  "tags": ["mocks", "lib"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/demo/mocks",
        "main": "libs/demo/mocks/src/index.ts",
        "tsConfig": "libs/demo/mocks/tsconfig.lib.json",
        "assets": ["libs/demo/mocks/*.md"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/demo/mocks/jest.config.cts"
      }
    }
  }
}
