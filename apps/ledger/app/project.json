{
  "name": "ledger-app",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "ldg",
  "sourceRoot": "apps/ledger/app/src",
  "tags": ["ledger", "app"],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/apps/ledger/app",
        "browser": "apps/ledger/app/src/main.ts",
        "tsConfig": "apps/ledger/app/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/ledger/app/public"
          }
        ],
        "styles": [
          "apps/ledger/app/src/tailwind.css",
          "apps/ledger/app/src/styles.scss"
        ],
        "stylePreprocessorOptions": {
          "includePaths": ["libs/shared/themes/src/lib/styles", "libs/ledger/themes/src/lib/styles"]
        }
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "1mb",
              "maximumError": "2mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "10kb",
              "maximumError": "16kb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        },
        "local-dev": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      }
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "defaultConfiguration": "development",
      "options": {
        "port": 4203
      },
      "configurations": {
        "production": {
          "buildTarget": "ledger-app:build:production"
        },
        "development": {
          "buildTarget": "ledger-app:build:development"
        },
        "local-dev": {
          "buildTarget": "ledger-app:build:local-dev"
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/ledger/app/jest.config.cts",
        "tsConfig": "apps/ledger/app/tsconfig.spec.json"
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "ledger-app:build",
        "staticFilePath": "dist/apps/ledger/app/browser",
        "spa": true
      }
    }
  }
}
