{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "paths": {
      "@nge/rxjs": ["./libs/shared/rxjs/src/index.ts"],
      "@nge/storybook": ["./libs/shared/storybook/src/index.ts"],
      "@nge/charts": ["./libs/shared/charts/src/index.ts"],
      "@nge/ui-design-library": [
        "./libs/shared/ui-design-library/src/index.ts"
      ],
      "@nge/themes": ["./libs/shared/themes/src/index.ts"],
      "@nge/date": ["./libs/shared/date/src/index.ts"],
      "@nge/calendar": ["./libs/shared/calendar/src/index.ts"],
      "@nge/ledger-models": ["./libs/ledger/models/src/index.ts"],
      "@nge/ledger-store": ["./libs/ledger/store/src/index.ts"],
      "@nge/ledger-themes": ["./libs/ledger/themes/src/index.ts"],
      "@nge/ledger-ui": ["./libs/ledger/ui/src/index.ts"],
      "@nge/ledger-design-library": [
        "./libs/ledger/design-library/src/index.ts"
      ],
      "@nge/ledger-utils": ["./libs/ledger/utils/src/index.ts"],
      "@nge/ledger-mocks": ["./libs/ledger/mocks/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
